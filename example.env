# Watchtower - environment variable example
# Copy this file to .env and fill in the values

# Polling interval in seconds (default: 86400 = 24h)
WATCHTOWER_POLL_INTERVAL=86400

# Or use a cron expression (overrides POLL_INTERVAL if set)
# WATCHTOWER_SCHEDULE=0 0 * * * *

# Enable the HTTP metrics endpoint (requires port 8080 exposed)
WATCHTOWER_HTTP_API_METRICS=true
WATCHTOWER_HTTP_API_UPDATE=false

# Token to protect the HTTP API (change this!)
WATCHTOWER_HTTP_API_TOKEN=changeme

# Remove old images after updating containers
WATCHTOWER_CLEANUP=true

# Log level: panic | fatal | error | warn | info | debug | trace
WATCHTOWER_LOG_LEVEL=info

# --- Notifications ---
# Provider: email | slack | msteams | gotify | shoutrrr
# WATCHTOWER_NOTIFICATIONS=email

# Email settings
# WATCHTOWER_NOTIFICATION_EMAIL_FROM=watchtower@example.com
# WATCHTOWER_NOTIFICATION_EMAIL_TO=admin@example.com
# WATCHTOWER_NOTIFICATION_EMAIL_SERVER=smtp.example.com
# WATCHTOWER_NOTIFICATION_EMAIL_SERVER_PORT=587
# WATCHTOWER_NOTIFICATION_EMAIL_SERVER_USER=user@example.com
# WATCHTOWER_NOTIFICATION_EMAIL_SERVER_PASSWORD=your_smtp_password

# Slack webhook
# WATCHTOWER_NOTIFICATION_SLACK_HOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Behaviour ---
# Only watch containers with label com.centurylinklabs.watchtower.enable=true
# WATCHTOWER_LABEL_ENABLE=true

# Run once and exit (useful for cron jobs)
# WATCHTOWER_RUN_ONCE=true
